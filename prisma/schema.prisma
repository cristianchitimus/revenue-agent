generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Platform {
  id          String   @id @default(cuid())
  slug        String   @unique // "remoteok", "wwr", "remotive", "himalayas", "hn", "reddit", "upwork-rss"
  name        String
  enabled     Boolean  @default(true)
  lastScanAt  DateTime?
  jobsFound   Int      @default(0)
  jobs        Job[]
  scanRuns    ScanRun[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id           String   @id @default(cuid())
  externalId   String   // Platform's own ID (URL, guid, etc.)
  platform     Platform @relation(fields: [platformId], references: [id])
  platformId   String

  title        String
  description  String   @db.Text
  company      String?
  location     String?
  remote       Boolean  @default(true)
  url          String

  budgetMin    Int?     // in USD cents
  budgetMax    Int?
  budgetType   String?  // "fixed", "hourly", "unknown"
  currency     String   @default("USD")

  skills       String[] // extracted skills/tags
  category     String?  // "fullstack", "design", "both", "other"

  matchScore   Int      @default(0)  // 0-100 relevance to user profile
  status       String   @default("new") // new, saved, applied, rejected, hidden

  postedAt     DateTime
  scrapedAt    DateTime @default(now())

  proposals    Proposal[]

  @@unique([platformId, externalId])
  @@index([status])
  @@index([matchScore])
  @@index([postedAt])
}

model Proposal {
  id         String   @id @default(cuid())
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId      String

  content    String   @db.Text
  wordCount  Int
  status     String   @default("draft") // draft, sent, won, lost
  sentAt     DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ScanRun {
  id          String   @id @default(cuid())
  platform    Platform @relation(fields: [platformId], references: [id])
  platformId  String

  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  status      String   @default("running") // running, success, error
  jobsFound   Int      @default(0)
  jobsNew     Int      @default(0)
  error       String?  @db.Text

  @@index([startedAt])
}

model Settings {
  id                String   @id @default("singleton")
  // User profile for matching + proposal generation
  displayName       String   @default("Cristian")
  headline          String   @default("Full-stack developer & designer")
  yearsExperience   Int      @default(5)
  hourlyRateUsd     Int      @default(40)

  // Skills (used for matching + proposals)
  primarySkills     String[] @default(["Next.js", "React", "TypeScript", "Node.js", "Prisma", "Supabase", "Tailwind CSS", "UI/UX Design", "Figma"])
  secondarySkills   String[] @default(["PostgreSQL", "Stripe", "Vercel", "Python", "branding", "landing pages"])

  // Matching filters
  minBudget         Int      @default(30000) // $300 in cents
  minMatchScore     Int      @default(50)
  excludeKeywords   String[] @default(["WordPress plugin", "Shopify template"])
  includeKeywords   String[] @default([])

  // Proposal prefs
  proposalTone      String   @default("friendly-professional")
  portfolioUrl      String?
  bio               String   @db.Text @default("I'm a full-stack engineer and designer who ships end-to-end: from mockup to deployed app. I specialize in Next.js + Supabase + Stripe builds and focus on startups that need speed + polish.")

  updatedAt         DateTime @updatedAt
}
